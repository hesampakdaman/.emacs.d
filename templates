org-mode

(confsrc
  "#+begin_src conf :tangle " (p "path") n
  r n
  "#+end_src"
  :post (org-edit-src-code))

typst-ts-mode

(rudinex "=== Exercise " (p "number") n
  "#quote(block: true)[" (p "text") "]" n n
  q n n
  "#qed")

zig-mode

(gwt "test \"" (p "description") "\" {" n>
  "// Given" n>
  (p "given") n n>
  "// When" n>
  (p "when") n n>
  "// Then" n>
  (p "then") n
  "}")